generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URI")
}

type Media {
  url      String
  publicId String
  width    Int?
  height   Int?
}

model Car {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  slug         String    @unique
  name         String
  brand        String
  category     String
  price        Float
  downPayment  Float     @default(0)
  emiFrom      Float     @default(0)
  tenure       Int       @default(60)
  year         Int
  fuel         String
  transmission String
  mileage      String    @default("")
  seating      Int       @default(5)
  engine       String    @default("")
  power        String    @default("")
  images       Media[]
  videos       Media[]
  features     String[]
  description  String    @default("")
  badge        String?
  featured     Boolean   @default(false)
  status       String    @default("available")
  published    Boolean   @default(true)
  soldAt       DateTime?

  // Finance offers / selling points
  priceType                String  @default("Price") // "Price" | "Finance"
  monthlyApprox            Boolean @default(true)
  freeInsurance            Boolean @default(false)
  freeRegistration         Boolean @default(false)
  zeroDownpayment          Boolean @default(false)
  firstPaymentAfter2Months Boolean @default(false)

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  applications Application[]

  @@index([brand])
  @@index([category])
  @@index([status])
  @@index([featured])
  @@index([published])
}

type ApplicationDoc {
  kind         String // emirates_id | visa | passport | salary_certificate | bank_statement
  publicId     String
  resourceType String @default("image")
  format       String @default("")
}

model Application {
  // id is set explicitly (minted at email-verification) so we can name the
  // Cloudinary document folder before the record exists.
  id    String @id @map("_id") @db.ObjectId

  // Human-friendly URL slug (e.g. ahmed-hassan-3f9a) — used in admin URLs.
  slug  String?

  // Applicant
  name       String
  mobile     String
  email      String
  homeMobile String?
  mother     String?

  // Address
  flat        String?
  building    String?
  street      String?
  area        String?
  city        String?
  homeAddress String?

  // Employment
  officeAddress  String?
  officeLandline String?

  // Banking
  salaryDate String?
  bankName   String?
  iban       String?

  // Obligations
  loanInstallment String?
  hasCards        String?
  cardLimit       String?
  cashLoan        String?

  // References
  ref1Name   String?
  ref1Mobile String?
  ref2Name   String?
  ref2Mobile String?

  documents ApplicationDoc[]

  car     Car?    @relation(fields: [carId], references: [id])
  carId   String? @db.ObjectId
  carName String?

  emailVerified Boolean  @default(true)
  status        String   @default("submitted") // submitted | in_review | approved | rejected
  reviewNote    String? // admin note / rejection reason, shown to the applicant
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([carId])
  @@index([email])
  @@index([slug])
}

/**
 * Master customer database — every kind of client (leads, applicants, closed,
 * no-deal, etc.). Auto-populated from enquiries & applications, and manageable
 * by the admin.
 */
model Customer {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  email       String?
  phone       String?
  status      String   @default("lead") // lead | active | customer | closed | no_deal | other
  source      String?  // enquiry | application | whatsapp | call | manual | wishlist
  carInterest String?
  notes       String?
  emailOptOut Boolean  @default(false)
  // Opted in via the "notify me when my car arrives" home-page section — used
  // to target stock-alert / new-arrival emails specifically at these people.
  futureInterest Boolean @default(false)
  lastContactedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([email])
  @@index([phone])
}

model OtpToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  email      String   @unique
  codeHash   String
  expiresAt  DateTime
  attempts   Int      @default(0)
  sentCount  Int      @default(1)
  lastSentAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Lead {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  type      String   @default("enquiry")
  name      String?
  phone     String?
  email     String?
  message   String?
  carId     String?
  carName   String?
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@index([carId])
}
