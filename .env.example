# Site
NEXT_PUBLIC_SITE_URL=https://yourdomain.ae

# Analytics (optional - leave blank to disable)
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GOOGLE_ADS_ID=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# Contact numbers are set in src/content/social.ts (not env).

# ─────────────────────────────────────────────────────────────
# Admin / backend (required for the admin panel & DB-backed cars)
# The public site falls back to seed data if MONGODB_URI is unset.
# ─────────────────────────────────────────────────────────────

# MongoDB (Atlas connection string)
MONGODB_URI=
# Optional: override the database name (defaults to the one in the URI, or "driveeasy")
MONGODB_DB=driveeasy

# Cloudinary (photos & videos)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Cloud name + API key exposed to the browser for the signed upload widget.
# These are NOT secrets — the widget runs in the browser and needs them to
# identify your Cloudinary account. The API *secret* above stays server-only.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_API_KEY=
# Cloudinary folder uploaded car media is stored in (default: driveeasy/cars)
CLOUDINARY_FOLDER_NAME=carimages

# Admin login (single shared account)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password
# Secret used to sign the admin session cookie + OTP/email-verify tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# Email (SMTP) — used to send OTP codes for the /services application form and
# approval/rejection/promo emails. Uses the Tasjeel-hosted mailbox.
# Port 587 with SMTP_SECURE=false uses STARTTLS; use 465 + true for SSL.
SMTP_HOST=mail.buyanddrive.ae
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=info@buyanddrive.ae
SMTP_PASSWORD=
# Optional display From; defaults to "Buy&Drive Cars <SMTP_USER>"
EMAIL_FROM=info@buyanddrive.ae
